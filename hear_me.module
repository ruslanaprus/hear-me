<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_insert().
 *
 * When a new node is created, queues it for background TTS pre-generation
 * if its bundle is listed in the hear_me.settings queue_bundles setting.
 *
 * The list of bundles is configured at Administration > Configuration >
 * Media > HearMe TTS Settings. No bundles are enabled by default (opt-in)
 */
function hear_me_entity_insert(EntityInterface $entity): void {
  \Drupal::service('hear_me.node_audio_queue')->queueNode($entity);
}

/**
 * Implements hook_entity_update().
 */
function hear_me_entity_update(EntityInterface $entity): void {
  $nodeAudioQueue = \Drupal::service('hear_me.node_audio_queue');
  if ($nodeAudioQueue->hasAudioSourceChanged($entity)) {
    $nodeAudioQueue->queueNode($entity);
  }
}

/**
 * Implements hook_cron().
 */
function hear_me_cron() {
  \Drupal::service('hear_me.cache_manager')->cleanup();
}
